# ==========================================
# AutheTrack - Comprehensive .gitignore
# ==========================================

# ─── DEPENDENCIES ────────────────────────────────────
node_modules/
**/node_modules/
dist/
build/
client/dist/
server/dist/
ml-service/venv/
ml-service/.venv/

# ─── ENVIRONMENT FILES ──────────────────────────────
# IMPORTANT: Track .env.example but NEVER commit .env
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
**/.env
server/.env
client/.env
ml-service/.env

# ─── SENSITIVE FILES ────────────────────────────────
# Firebase service account key — DO NOT COMMIT
**/authetrack-service-key.json
**/*-service-key.json
**/serviceAccountKey.json
server/config/authetrack-service-key.json

# ─── ML MODEL FILES ────────────────────────────────
# Large binary model files (consider using Git LFS)
*.pkl
*.joblib
*.h5
*.model
ml-service/models/*.pkl
ml-service/*.pkl

# ─── PYTHON ─────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ─── NODE & NPM ──────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
package-lock.json
yarn.lock

# ─── LOGS ────────────────────────────────────────
logs/
*.log
combined.log
error.log
ml_service.log

# ─── DATABASE ───────────────────────────────────
dump.rdb
*.sqlite
*.sqlite3
.db

# ─── OS FILES ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE & EDITOR ──────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
*.swp
*.swo
*~
.vimrc

# ─── TESTING ──────────────────────────────────
.nyc_output/
coverage/
test-results/
junit.xml

# ─── BUILD ARTIFACTS ─────────────────────────
.turbo/
.env.local/

# ─── LARGE/TEMPORARY FILES ──────────────────
*.tmp
*.temp
*.bak
*.backup
*.orig

# ─── TYPESCRIPT ──────────────────────────────
*.tsbuildinfo
dist/
build/

# ─── NODE MODULES IN ROOT ──────────────────
node_modules/
package-lock.json
