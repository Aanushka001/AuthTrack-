# ==========================================
# AUTHETRACK - ENVIRONMENT CONFIGURATION
# Make a copy: cp .env.example .env
# Then fill in all your actual values
# ==========================================

# ── Ports ──────────────────────────────────────────────
PORT=3001
ML_SERVICE_PORT=5000

# ── Node environment ───────────────────────────────────
NODE_ENV=development

# ── Firebase (server-side admin SDK) ───────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id

# ── Firebase (client-side — MUST have VITE_ prefix) ────
# Get these from Firebase Console → Project Settings → General (under SDK setup)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Client API URLs ────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_WS_URL=http://localhost:3001

# ── Redis (for caching & job queues) ───────────────────
# Local: redis://localhost:6379
# Cloud: redis://user:password@host:port
REDIS_URL=redis://localhost:6379

# ── ML Service ─────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5000

# ── Authentication ────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters

# ── PayPal Integration (optional) ──────────────────────
# Sandbox credentials: https://developer.paypal.com/
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ── Email Service (optional) ───────────────────────────
EMAIL_SERVICE_API_KEY=your_email_api_key
GEOLOCATION_API_KEY=your_geolocation_api_key

# ── CORS Configuration ────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_ALLOW_CREDENTIALS=true

# ── ML Service Configuration ──────────────────────────
FLASK_ENV=development
FLASK_APP=app.py
MODEL_PATH=./models/
LOG_LEVEL=INFO
REQUIRE_AUTH=false
API_KEY=89a6f454a6455c2a9cc85cee4eda59fe61599c632996e8d23300b63ae3efd97d

# ── Database (optional — if using MongoDB instead of Firebase) ──
MONGODB_URI=mongodb://localhost:27017/authetrack